#!/usr/bin/env bash
set -euo pipefail

if [[ "${EUID}" -ne 0 ]]; then
  exec sudo -H --preserve-env=DOTFILE_PROFILE,NIX_CONFIG "$0" "$@"
fi

host="$(scutil --get LocalHostName 2>/dev/null || hostname -s || echo "")"
if [[ -z "${host}" && -n "${HOSTNAME:-}" ]]; then
  host="${HOSTNAME}"
fi
user="${SUDO_USER:-${USER:-$(id -un)}}"
profile="${DOTFILE_PROFILE:-personal}"

if [[ -z "${host}" ]]; then
  echo "HOSTNAME is required" >&2
  exit 1
fi

if [[ -z "${user}" ]]; then
  echo "USER is required" >&2
  exit 1
fi

mkdir -p /nix/var/nix/profiles/per-user/root/channels
HOSTNAME="${host}" USER="${user}" nix run --accept-flake-config nix-darwin/master#darwin-rebuild -- switch --impure --flake ".#${profile}"
